build/
.env
.env.*
.claude/
node_modules/
*.wasm
*.tgz
.playwright-mcp/
dist/
.wrangler/

# Tracked test fixtures (published binaries we test against)
!tests/pkgs/**/*.wasm
!tests/emnapi/wasm/*.wasm

# Rolldown binding wasm is ~12MB — too big for git. Fetched on-demand
# by scripts/install-rolldown.sh; the test skips when missing.
tests/pkgs/rolldown/package/rolldown-binding.wasm32-wasi.wasm

# Tracked guest C sources (the compiled .wasm output stays ignored —
# CI rebuilds them via scripts/build-guests.sh)
!tests/guest/*.c

# Third-party assets vendored for local repros (not committed —
# setup instructions live in each repro's README.md).
tests/ext/oxide-repro/oxide.wasm
tests/ext/oxide-repro/vendor/
